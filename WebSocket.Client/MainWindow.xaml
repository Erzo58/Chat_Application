<Window x:Class="WebSocket.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WPF Real-Time Chat" Height="400" Width="450">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Meno:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox x:Name="UsernameBox" Width="100" Text="Client1" Margin="0,0,10,0" VerticalAlignment="Center"/>
            <Button Content="Pripojiť na Server" Click="Connect_Click" Width="120" Padding="5"/>
        </StackPanel>

        <ListBox x:Name="ChatListBox" Grid.Row="1" Margin="0,0,0,10" Background="#F0F0F0"/>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="MessageInputBox" Grid.Column="0" Margin="0,0,10,0" Padding="5"/>
            <Button Content="Odoslať" Grid.Column="1" Click="Send_Click" Width="80"/>
        </Grid>
    </Grid>
</Window>